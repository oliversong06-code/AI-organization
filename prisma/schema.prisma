// AI 회사 운영 웹앱 — 데이터 모델
// SQLite는 네이티브 enum을 지원하지 않으므로 상태값은 String으로 저장하고,
// 허용 값의 단일 진실 소스는 src/lib/enums.ts(zod enum)에 둔다.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────────────────
// 회사 / 사무실 공간
// ─────────────────────────────────────────────────────────

model Company {
  id          String   @id @default(cuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// 물리적 사무실 공간(업무공간/개인오피스/회의실/휴게공간/공용 결과물 공간 등).
/// 부서나 실제 직원을 의미하지 않는다 — 부서가 나중에 이 공간에 배정될 뿐이다.
model OfficeZone {
  id                 String       @id @default(cuid())
  key                String       @unique
  name               String // 내부 식별용 이름(불변) — 예: "개방형 업무 공간 1"
  defaultDisplayName String       @default("미배정 공간") // 부서 미배정 시 화면 표시 기본값("미배정 공간 N", 백필로 확정)
  displayName        String? // 현재 화면 표시 이름 — null이면 defaultDisplayName 사용. 부서 배정 시 부서명, 해제/보관 시 다시 null
  kind               String
  rectNormX0         Float
  rectNormY0         Float
  rectNormX1         Float
  rectNormY1         Float
  departments        Department[]
  employees          Employee[]
  seats              Seat[]
  createdAt          DateTime     @default(now())
}

/// zone 안의 좌석 슬롯 — 배경 SVG의 책상 그래픽과 동일 좌표를 사용해 캐릭터-가구 정렬을 보장한다.
model Seat {
  id           String     @id @default(cuid())
  officeZoneId String
  officeZone   OfficeZone @relation(fields: [officeZoneId], references: [id])
  index        Int
  normX        Float // zone 내부 정규화 좌표(0..1) — resolveEmployeeUV와 동일 좌표계
  normY        Float
  kind         String     @default("desk")
  employeeId   String?    @unique
  employee     Employee?  @relation(fields: [employeeId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([officeZoneId, index])
}

// ─────────────────────────────────────────────────────────
// 부서 / 직원 / 스킬
// ─────────────────────────────────────────────────────────

model Department {
  id                String                @id @default(cuid())
  name              String
  description       String?
  colorTag          String?
  officeZoneId      String?
  officeZone        OfficeZone?           @relation(fields: [officeZoneId], references: [id])
  status            String                @default("active") // active|archived
  version           Int                   @default(1)
  employees         Employee[]
  artifacts         Artifact[]
  artifactLinks     ArtifactDepartment[]
  dataAssets        DataAsset[]
  dataAssetLinks    DataAssetDepartment[]
  approvalRequestId String?
  createdAt         DateTime              @default(now())
  archivedAt        DateTime?
}

model Employee {
  id                String              @id @default(cuid())
  name              String
  role              String
  rank              Int                 @default(1) // 1(최하)~4(최상) — 기존 행은 임의로 올리지 않고 1로 마이그레이션됨
  departmentId      String?
  department        Department?         @relation(fields: [departmentId], references: [id])
  status            String              @default("idle") // idle|queued|running|awaiting_approval|needs_review|reviewing|revision_requested|completed|failed|paused|review_blocked|archived
  officeZoneId      String
  officeZone        OfficeZone          @relation(fields: [officeZoneId], references: [id])
  posX              Float
  posY              Float
  direction         String              @default("down") // up|down|left|right
  scale             Float               @default(1)
  avatarId          String
  currentTaskId     String?
  version           Int                 @default(1)
  skills            EmployeeSkill[]
  assignedTasks     Task[]              @relation("AssignedTasks")
  seat              Seat?
  reviewDecisions   ReviewDecision[]
  ownedDataAssets   DataAsset[]
  dataAssetLinks    DataAssetEmployee[]
  approvalRequestId String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  archivedAt        DateTime?
}

model Skill {
  id                    String          @id @default(cuid())
  name                  String
  description           String?
  category              String
  source                String // builtin|mcp|external
  connectionType        String // none|api_key|oauth_stub|local_tool
  inputSchema           Json
  outputSchema          Json
  permissions           Json // string[]
  enabled               Boolean         @default(false)
  installed             Boolean         @default(false)
  healthStatus          String          @default("available") // available|installation_required|configuration_required|connected|disabled|error
  configuration         Json?
  instructions          String? // 직원이 이 스킬을 어떻게 써야 하는지
  allowedTools          Json? // string[]
  compatibleRanks       Json? // number[] (1~4)
  compatibleDepartments Json? // string[] (department id)
  validationStatus      String          @default("unvalidated") // unvalidated|validating|passed|failed
  version               Int             @default(1)
  employees             EmployeeSkill[]
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}

model EmployeeSkill {
  id         String   @id @default(cuid())
  employeeId String
  skillId    String
  employee   Employee @relation(fields: [employeeId], references: [id])
  skill      Skill    @relation(fields: [skillId], references: [id])
  addedAt    DateTime @default(now())

  @@unique([employeeId, skillId])
}

// ─────────────────────────────────────────────────────────
// 업무
// ─────────────────────────────────────────────────────────

model Task {
  id                       String          @id @default(cuid())
  title                    String
  description              String
  assignedEmployeeId       String?
  assignedEmployee         Employee?       @relation("AssignedTasks", fields: [assignedEmployeeId], references: [id])
  collaboratingEmployeeIds Json // string[]
  status                   String // queued|running|needs_review|completed|failed|paused|cancelled|archived (draft/awaiting_approval은 실제 행에 존재하지 않는 가상 상태)
  statusBeforePause        String? // pause 직전 상태 — resume 시 이 값으로 복귀
  priority                 String          @default("normal") // low|normal|high|urgent
  inputFiles               Json // string[] (workspace-relative)
  requiredSkills           Json // string[]
  requestedPermissions     Json // string[]
  progress                 Int             @default(0)
  resultSummary            String?
  errorMessage             String?
  retryable                Boolean         @default(false)
  version                  Int             @default(1)
  approvalRequestId        String?
  createdAt                DateTime        @default(now())
  approvedAt               DateTime?
  startedAt                DateTime?
  completedAt              DateTime?
  steps                    TaskStep[]
  logs                     TaskLog[]
  artifacts                Artifact[]
  taskArtifactLinks        TaskArtifact[]
  executionJobs            ExecutionJob[]
  dataAssetLinks           DataAssetTask[]
}

/// 승인 없이 자동 실행되는 업무 실행 잡 — Worker가 원자적으로 claim한다.
model ExecutionJob {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id])
  status      String    @default("pending") // pending|claimed|running|completed|failed
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  workerId    String?
  lockedAt    DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  lastError   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TaskStep {
  id          String    @id @default(cuid())
  taskId      String
  task        Task      @relation(fields: [taskId], references: [id])
  stepNumber  Int
  title       String
  status      String // pending|running|completed|failed|skipped
  output      Json?
  startedAt   DateTime?
  completedAt DateTime?
}

model TaskLog {
  id         String   @id @default(cuid())
  taskId     String
  task       Task     @relation(fields: [taskId], references: [id])
  employeeId String?
  timestamp  DateTime @default(now())
  level      String // info|warn|error
  message    String
}

// ─────────────────────────────────────────────────────────
// 결과물
// ─────────────────────────────────────────────────────────

model Artifact {
  id                  String               @id @default(cuid())
  taskId              String?
  task                Task?                @relation(fields: [taskId], references: [id])
  employeeId          String?
  departmentId        String? // 담당 직원의 부서에서 자동 유도(기본 부서) — 공동 부서는 ArtifactDepartment로 표현
  department          Department?          @relation(fields: [departmentId], references: [id])
  title               String
  summary             String?
  fileName            String
  filePath            String // workspace-relative, path-guard 검증됨(최신 버전 파일 — 상세는 ArtifactVersion 참고)
  mimeType            String
  size                Int
  sourceType          String // task_output|manual_import|external_sync|excel_register
  externalSourceId    String? // 예: manifest runId
  importance          Int                  @default(2) // 1~4, 검수 강도 결정
  currentReviewStatus String               @default("approved") // pending|reviewing|approved|revision_requested|rejected|blocked — 최신 버전과 동기화되는 편의 필드
  legacy              Boolean              @default(false) // Phase 2 이전에 검수 시스템 없이 생성된 결과물
  metadata            Json?
  taskLinks           TaskArtifact[]
  departmentLinks     ArtifactDepartment[]
  versions            ArtifactVersion[]
  createdAt           DateTime             @default(now())
  archivedAt          DateTime?
}

/// 결과물은 항상 새 버전으로 쌓인다 — 기존 파일을 덮어쓰지 않는다.
model ArtifactVersion {
  id               String           @id @default(cuid())
  artifactId       String
  artifact         Artifact         @relation(fields: [artifactId], references: [id])
  versionNumber    Int
  filePath         String
  fileName         String
  mimeType         String
  size             Int
  format           String // markdown|pdf|xlsx|csv|other
  authorEmployeeId String?
  reviewStatus     String           @default("pending") // pending|reviewing|approved|revision_requested|rejected|blocked
  revisionCount    Int              @default(0)
  createdAt        DateTime         @default(now())
  reviewDecisions  ReviewDecision[]

  @@unique([artifactId, versionNumber])
}

model ArtifactDepartment {
  id           String     @id @default(cuid())
  artifactId   String
  departmentId String
  artifact     Artifact   @relation(fields: [artifactId], references: [id])
  department   Department @relation(fields: [departmentId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([artifactId, departmentId])
}

/// importance별 검수 체인 규칙(하드코딩 금지) — src/lib/review/reviewChain.ts의 chainMode로 해석
model ReviewPolicy {
  id                   String   @id @default(cuid())
  importance           Int      @unique // 1~4
  description          String?
  chainMode            String // author_plus_one|sequential_to_rank3|min3_then_rank4|full_chain_rank4
  finalReviewerMinRank Int // 참고/표시용
  maxRevisions         Int      @default(3)
  strictness           String   @default("normal") // normal|strict
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model ReviewDecision {
  id                 String          @id @default(cuid())
  artifactVersionId  String
  artifactVersion    ArtifactVersion @relation(fields: [artifactVersionId], references: [id])
  reviewerEmployeeId String
  reviewerEmployee   Employee        @relation(fields: [reviewerEmployeeId], references: [id])
  reviewerRank       Int
  sequenceIndex      Int // 이 버전 검수 체인에서의 순서(0부터)
  status             String          @default("pending") // pending|reviewing|approved|revision_requested|rejected|blocked
  criteria           String?
  issuesFound        String?
  revisionRequest    String?
  decisionReason     String?
  decidedAt          DateTime?
  createdAt          DateTime        @default(now())
}

model TaskArtifact {
  id         String   @id @default(cuid())
  taskId     String
  artifactId String
  task       Task     @relation(fields: [taskId], references: [id])
  artifact   Artifact @relation(fields: [artifactId], references: [id])
  relation   String   @default("referenced") // produced|referenced
  linkedAt   DateTime @default(now())

  @@unique([taskId, artifactId])
}

// ─────────────────────────────────────────────────────────
// 자동화
// ─────────────────────────────────────────────────────────

model Automation {
  id                   String          @id @default(cuid())
  name                 String
  description          String?
  taskInstruction      String
  assignedEmployeeId   String?
  scheduleType         String // interval|cron|manual|external
  scheduleExpression   String?
  timezone             String?
  requiredSkills       Json
  requiredIntegrations Json
  outputFormat         String // file|artifact|summary
  outputLocation       String?
  approvalMode         String          @default("required") // required|pre_approved
  enabled              Boolean         @default(true)
  externalScheduleId   String?
  lastRunAt            DateTime?
  nextRunAt            DateTime?
  lastStatus           String?
  consecutiveFailures  Int             @default(0)
  version              Int             @default(1)
  approvalRequestId    String?
  createdAt            DateTime        @default(now())
  archivedAt           DateTime?
  runs                 AutomationRun[]
}

model AutomationRun {
  id           String     @id @default(cuid())
  automationId String
  automation   Automation @relation(fields: [automationId], references: [id])
  runId        String     @unique // ImportedManifest.runId와 상관관계
  source       String // local_manual|external_import
  status       String // running|completed|failed
  summary      String?
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
}

// ─────────────────────────────────────────────────────────
// AI 직원용 내부 데이터 공간 (사용자용 결과물 보관함과 별개)
// ─────────────────────────────────────────────────────────

model DataAsset {
  id              String      @id @default(cuid())
  name            String
  description     String?
  dataType        String
  storagePath     String // workspace 내부 승인된 data workspace 상대경로, path-guard 검증
  mimeType        String
  size            Int
  departmentId    String?
  department      Department? @relation(fields: [departmentId], references: [id])
  ownerEmployeeId String?
  ownerEmployee   Employee?   @relation(fields: [ownerEmployeeId], references: [id])
  sourceType      String // task_input|approved_integration|manual_register
  sourceUri       String?
  provenance      String?
  collectedAt     DateTime?
  validFrom       DateTime?
  validUntil      DateTime?
  sensitivity     String      @default("internal") // public|internal|confidential
  version         Int         @default(1)
  checksum        String // 중복 감지용
  status          String      @default("active") // active|archived
  metadata        Json?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  departmentLinks DataAssetDepartment[]
  employeeLinks   DataAssetEmployee[]
  taskLinks       DataAssetTask[]
  accessLogs      DataAccessLog[]
}

model DataAssetDepartment {
  id           String     @id @default(cuid())
  dataAssetId  String
  departmentId String
  dataAsset    DataAsset  @relation(fields: [dataAssetId], references: [id])
  department   Department @relation(fields: [departmentId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([dataAssetId, departmentId])
}

model DataAssetEmployee {
  id          String    @id @default(cuid())
  dataAssetId String
  employeeId  String
  dataAsset   DataAsset @relation(fields: [dataAssetId], references: [id])
  employee    Employee  @relation(fields: [employeeId], references: [id])
  createdAt   DateTime  @default(now())

  @@unique([dataAssetId, employeeId])
}

model DataAssetTask {
  id          String    @id @default(cuid())
  dataAssetId String
  taskId      String
  dataAsset   DataAsset @relation(fields: [dataAssetId], references: [id])
  task        Task      @relation(fields: [taskId], references: [id])
  relation    String    @default("used") // used|produced
  createdAt   DateTime  @default(now())

  @@unique([dataAssetId, taskId])
}

model DataAccessLog {
  id          String    @id @default(cuid())
  dataAssetId String
  dataAsset   DataAsset @relation(fields: [dataAssetId], references: [id])
  employeeId  String?
  taskId      String?
  action      String // read|write|search|reuse
  timestamp   DateTime  @default(now())
}

// ─────────────────────────────────────────────────────────
// 승인 / 연동 / 로그 / 설정
// ─────────────────────────────────────────────────────────

model ApprovalRequest {
  id              String    @id @default(cuid())
  entityType      String // department|employee|task|automation|skill|integration
  action          String // create|update|archive|move|assign|install_request|disable|configure ...
  relatedEntityId String? // update/archive/assign 대상 기존 행
  payload         Json // action별 Zod 스키마로 검증된 제안 데이터
  summary         String
  riskLevel       String    @default("standard") // standard|sensitive
  status          String    @default("pending") // pending|approved|rejected|expired
  requestedBy     String    @default("claude_code")
  rejectionReason String?
  idempotencyKey  String?   @unique
  entityVersion   Int? // update/archive/assign 제안 시 대상의 version 스냅샷
  expiresAt       DateTime
  createdAt       DateTime  @default(now())
  resolvedAt      DateTime?
  resolvedBy      String?
}

model Integration {
  id            String    @id @default(cuid())
  name          String
  kind          String // local_folder|google_drive_sync|git_repo|excel_watch|generic
  config        Json // 예: { syncFolderPath }
  status        String    @default("not_configured") // not_configured|configured|error
  accessMode    String    @default("read_only") // read_only|read_write(workspace 루트에만 해당)
  version       Int       @default(1)
  lastCheckedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ActivityLog {
  id                String   @id @default(cuid())
  timestamp         DateTime @default(now())
  actor             String // claude_code|user|system
  action            String // 예: "employee.propose", "approval.approve", "task.pause"
  entityType        String?
  entityId          String?
  detail            Json?
  approvalRequestId String?
}

model AppSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model ImportedManifest {
  id                 String   @id @default(cuid())
  runId              String   @unique
  automationId       String?
  sourceFilePath     String
  rawPayload         Json
  status             String // imported|skipped_duplicate|invalid
  createdArtifactIds Json // string[]
  importedAt         DateTime @default(now())
}
